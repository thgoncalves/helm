{
  "name": "@helm/infra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "synth": "cdk synth",
    "deploy:main": "cdk deploy --all -c env=main --profile helm --require-approval never",
    "deploy:dev": "cdk deploy --all -c env=dev --profile helm --require-approval never",
    "diff:main": "cdk diff -c env=main --profile helm"
  },
  "dependencies": {
    "aws-cdk-lib": "2.253.1",
    "constructs": "10.6.0"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "aws-cdk": "2.1121.0",
    "tsx": "4.19.3",
    "typescript": "5.8.3"
  }
}
