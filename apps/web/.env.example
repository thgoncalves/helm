# Helm frontend environment variables
# Copy this file to .env.local and fill in the values for your target environment.
# Never commit .env.local — it is gitignored by the root .gitignore.
#
# Values below are for the `main` (prod) environment.
# For the `dev` environment, use the dev Cognito pool: ca-central-1_LeWajbbXR
# and the dev API Gateway URL (check AWS Console or ask the project owner).
#
# Find these values in:
#   - AWS Console → Cognito → User Pools (for pool ID and client ID)
#   - AWS Console → API Gateway → your API → Stages (for API URL)
#   - Or in the Amplify Console under the relevant branch's environment variables.

VITE_API_URL=https://your-api-gateway-id.execute-api.ca-central-1.amazonaws.com
VITE_AWS_REGION=ca-central-1
VITE_COGNITO_USER_POOL_ID=ca-central-1_XXXXXXXXX
VITE_COGNITO_USER_POOL_CLIENT_ID=your-user-pool-client-id
